            min-height: 228px;
        }

        .ff-calendar-grid.is-month-view,
        .ff-calendar-grid.is-year-view {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .ff-calendar-cell {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 42px;
            border: 1px solid transparent;
            border-radius: 8px;
            background: transparent;
            color: #1f3347;
            font-size: 13px;
            cursor: pointer;
        }

        .ff-calendar-cell.is-muted {
            color: #bcc6d0;
        }

        .ff-calendar-cell.is-selected {
            border-color: #1580ed;
            background: #d9ebff;
