            display: grid;
            grid-template-columns: minmax(240px, 1.45fr) minmax(150px, 0.9fr) minmax(120px, 0.8fr) minmax(170px, 1fr) minmax(280px, 1.2fr);
            gap: 24px;
            align-items: center;
