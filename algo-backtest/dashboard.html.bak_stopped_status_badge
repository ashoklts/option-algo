        .ff-calendar-popup[hidden] {
            display: none !important;
        }

        .ff-calendar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 12px;
        }

        .ff-calendar-title {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            color: #1f3347;
            font-size: 14px;
            font-weight: 700;
        }

        .ff-calendar-title-btn {
            border: 0;
            background: transparent;
            padding: 0;
            color: #1f3347;
            font-size: 14px;
