            border-radius: 8px;
            background: #fff;
            color: #1f3347;
            font-size: 13px;
            font-weight: 500;
        }

        .ff-calendar-wrap {
            position: relative;
        }

        .ff-calendar-trigger {
            display: inline-flex;
