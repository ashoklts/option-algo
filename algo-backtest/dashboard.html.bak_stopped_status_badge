            background: #f7efe4;
            color: #1f2937;
            font-size: 18px;
            font-weight: 700;
            line-height: 1;
            text-align: center;
        }

        .ff-deployed-section {
            margin: 28px 16px 0;
        }

        .ff-listening-toolbar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 12px;
            margin: 0 0 14px;
            padding: 12px 14px;
            border: 1px solid #dbe4ee;
            border-radius: 10px;
            background: #f8fbff;
        }

        .ff-listening-input,
        .ff-listening-select {
            height: 38px;
