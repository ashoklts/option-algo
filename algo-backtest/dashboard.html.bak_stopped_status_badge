        .ff-calendar-icon {
            width: 16px;
            height: 16px;
            color: #1f3347;
            flex: 0 0 auto;
        }

        .ff-calendar-popup {
            position: absolute;
            top: calc(100% + 8px);
            left: 0;
            z-index: 30;
            width: 310px;
            padding: 12px;
            border: 1px solid #dbe4ee;
            border-radius: 10px;
            background: #fff;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
